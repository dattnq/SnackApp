<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.snackapp.admin">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- Android < 13 dùng READ_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_snack_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SnackAdmin">

        <!-- Splash / Entry point -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Auth -->
        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false"/>

        <activity
            android:name=".auth.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Admin -->
        <activity
            android:name=".admin.AdminMainActivity"
            android:exported="false"/>

        <activity
            android:name=".admin.AddEditProductActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Customer -->
        <activity
            android:name=".customer.CustomerMainActivity"
            android:exported="false"/>

        <activity
            android:name=".customer.CartActivity"
            android:exported="false"/>

        <activity
            android:name=".customer.ProductDetailActivity"
            android:exported="false"/>

    </application>
</manifest>